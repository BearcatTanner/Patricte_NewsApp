<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Patricte_NewsApp.Pages.NewsDetailsPage"
             Title="NewsDetailsPage">
    <Grid RowDefinitions="auto, auto, auto, *"
       >
        <Label Grid.Row="0"
            Text="News Details"
            FontSize="Title"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            Padding="20"/>
        <Image Grid.Row="1" x:Name="Img"/>
        <Label Grid.Row="2" x:Name="LblTitle" FontSize="Large" FontAttributes="Bold"/>
        <Label Grid.Row="3" x:Name="LblContent"/>
    </Grid>
</ContentPage>